th,\r\n   '% of Incidents closed with Article Relationship' AS Incidents,\r\n   COUNT(DISTINCT(`HPD:Help Desk`.`Incident Number`)) AS Per\r\nFROM\r\n`AR System Schema`.`HPD:Help Desk`\r\nLEFT OUTER JOIN `AR System Schema`.`HPD:Associations`\r\nON (`HPD:Help Desk`.`Incident Number`= `HPD:Associations`.`Request ID02`)\r\nWHERE\r\n    (`HPD:Help Desk`.`Closed Date` \u003e= $__from/1000 and `HPD:Help Desk`.`Closed Date` \u003c= $__to/1000)\r\n    AND `HPD:Help Desk`.`Status` IN ('Closed')\r\n    AND `HPD:Associations`.`Association Type01` = 49000 AND `HPD:Associations`.`Request Type01` = 'RKM Solution'\r\nGROUP BY\r\n   datename('mm',`HPD:Help Desk`.`Closed Date`),\r\n   YEAR(`HPD:Help Desk`.`Closed Date`)\r\n\r\nUNION ALL\r\n\r\nSELECT DISTINCT\r\n   'Not Available' AS RelationshipType,\r\n   STRCONVERT(YEAR(`HPD:Help Desk`.`Closed Date`),'CHARACTER200') + ' - ' + SubStr(datename('mm',`HPD:Help Desk`.`Closed Date`),0,2) AS YearMonth,\r\n   '% of Incidents closed with Article Relationship' AS Incidents,\r\n   COUNT(DISTINCT(`HPD:Help Desk`.`Incident Number`)) AS Per\r\nFROM `AR System Schema`.`HPD:Help Desk`\r\nWHERE\r\n    (`HPD:Help Desk`.`Closed Date` \u003e= $__from/1000 AND `HPD:Help Desk`.`Closed Date` \u003c= $__to/1000) AND\r\n    `HPD:Help Desk`.`Status` IN ('Closed')\r\n     AND NOT EXISTS (\r\n        SELECT 1 \r\n        FROM `AR System Schema`.`HPD:Associations` \r\n        WHERE `HPD:Associations`.`Request ID02` = `HPD:Help Desk`.`Incident Number`\r\n        AND `HPD:Associations`.`Request Type01` = 'RKM Solution'\r\n    )\r\nGROUP BY\r\n   datename('mm',`HPD:Help Desk`.`Closed Date`),\r\n   YEAR(`HPD:Help Desk`.`Closed Date`)"},"sourceType":"remedy"}],"title":"KCS Knowledge efficiency - Incident and Knowledge relationship","transformations":[{"id":"organize","options":{"excludeByName":{},"indexByName":{},"renameByName":{"RelationshipType":"Relationship Type","YearMonth":"Year-Month"}}}],"type":"bmc-ade-cross-tab"},{"datasource":"BMC Helix","fieldConfig":{