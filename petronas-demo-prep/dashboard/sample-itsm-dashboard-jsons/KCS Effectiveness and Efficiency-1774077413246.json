r\n         COUNT(`RKM:Associations`.`RelatedEntityPrimaryID`) \u003e 10\r\n         AND COUNT(`RKM:Associations`.`RelatedEntityPrimaryID`) \u003c= 50\r\n      ) THEN '4'\r\n      WHEN (\r\n         COUNT(`RKM:Associations`.`RelatedEntityPrimaryID`) \u003e 50\r\n         AND COUNT(`RKM:Associations`.`RelatedEntityPrimaryID`) \u003c= 100\r\n      ) THEN '5'\r\n      ELSE '6'\r\n   END) AS UseCountRange_OnlyForSorting,\r\n   `RKM:KnowledgeArticleManager`.`ArticleStatusEnglish` AS ArticleStatus,\r\n   COUNT(DISTINCT(`RKM:Associations`.`KAMDocID`)) AS NumberOfArticles\r\nFROM `AR System Schema`.`RKM:Associations`\r\nINNER JOIN `AR System Schema`.`RKM:KnowledgeArticleManager`\r\nON (\r\n   `RKM:Associations`.`KAMDocID` = `RKM:KnowledgeArticleManager`.`DocID`\r\n)\r\nWHERE (\r\n   `RKM:Associations`.`Association Type01` IN ('Resolved')\r\n   AND `RKM:KnowledgeArticleManager`.`ArticleStatusEnglish` NOT IN ('Cancelled')\r\n   AND `RKM:KnowledgeArticleManager`.`zTmp_IsLastVersion` IN ('Yes')\r\n)\r\nGROUP BY \r\n   `RKM:Associations`.`KAMDocID`,\r\n   `RKM:KnowledgeArticleManager`.`ArticleStatusEnglish`\r\n) as t1\r\ngroup by t1.ArticleStatus,t1.UseCountRange, t1.UseCountRange_OnlyForSorting\r\norder by t1.UseCountRange_OnlyForSorting"},"sourceType":"remedy"}],"title":"KCS : Article reuse","type":"bmc-ade-bar"},{"datasource":"BMC Helix","fieldConfig":{"defaults":{"custom":{"displayMode":"auto","filterable":false},"mappings":[],"thresholds":{"mode":"absolute","steps":[{"color":"green","value":null},{"color":"red","value":80}]}},"overrides":[{"matcher":{"id":"byName","options":"Article ID"},"properties":[{"id":"links","value":[{"targetBlank":true,"title":"View Article","url":"https://helixone-demo-smartit.onbmc.com/smartit/app/#/knowledge/${__data.fields[\"Instance ID\"]}"}]},{"id":"custom.width","value":130}]},{"matcher":{"id":"byName","options":"Article Usage Count"},"properties":[{"id":"custom.width","value":169}]},{"matcher":{"id":"byName","options":"Article Status"},"prop