.`Investigation Driver` AS C3,\r\n      `PBM:Problem Investigation`.`Urgency` AS C4,\r\n      `PBM:Problem Investigation`.`Priority` AS C5,\r\n      `PBM:Problem Investigation`.`Submitter` AS C6,\r\n      `PBM:Problem Investigation`.`First Reported On` AS C7,\r\n      `PBM:Problem Investigation`.`Invesitgation Status Reason` AS C8,\r\n      `PBM:Problem Investigation`.`Categorization Tier 1` AS C9,\r\n      `PBM:Problem Investigation`.`Categorization Tier 2` AS C10,\r\n      `PBM:Problem Investigation`.`Categorization Tier 3` AS C11,\r\n      `PBM:Problem Investigation`.`Product Categorization Tier 1` AS C12,\r\n      `PBM:Problem Investigation`.`Product Categorization Tier 2` AS C13,\r\n      `PBM:Problem Investigation`.`Product Categorization Tier 3` AS C14,\r\n      `PBM:Problem Investigation`.`Product Name` AS C15,\r\n      `PBM:Problem Investigation`.`Last Modified By` AS C16,\r\n      `PBM:Problem Investigation`.`Last Modified Date` AS C17,\r\n      `PBM:Problem Investigation`.`Target Resolution Date` AS C19,\r\n      `PBM:Problem Investigation`.`Assigned Group` AS C20,\r\n      SUBSTR(`PBM:Problem Investigation`.`Assigned Support Organization`,0,(CHARINDEX('-',`PBM:Problem Investigation`.`Assigned Support Organization`,1) - 2)) AS C21,\r\n      `PBM:Problem Investigation`.`Assigned Support Organization` AS C22,\r\n      SUBSTR(`PBM:Problem Investigation`.`Assigned Group Pblm Mgr`,0,(CHARINDEX('-',`PBM:Problem Investigation`.`Assigned Group Pblm Mgr`,1) - 2)) AS C25,\r\n      `PBM:Problem Investigation`.`Assigned Group Pblm Mgr` AS C23,\r\n      `PBM:Problem Investigation`.`Support Organization Pblm Mgr` AS C24,\r\n      `PBM:Problem Investigation`.`InstanceId` AS C28\r\n   FROM `AR System Schema`.`PBM:Problem Investigation`\r\n   INNER JOIN `AR System Schema`.`AST:BusinessService` AS `AST:BUSINESSSERVICE`\r\n   ON (`PBM:Problem Investigation`.`ServiceCI` = `AST:BUSINESSSERVICE`.`Name`)\r\n   LEFT OUTER JOIN (\r\n    SELECT \r\n   T0.C1 as problemid,\r\n   T1.C3 as changeid,\r\n   T1.C4 as changetiming\r\nFROM (\r\n   SELECT DISTINCT\r\n      `PBM:Problem Investigation`.`Problem Investigation ID` AS C1\r\n   FROM `AR System Schema`.`PBM:Problem Investigation`\r\n   WHERE (`PBM:Problem Investigation`.`Problem Investigation ID` IS NOT NULL)\r\n   AND (`PBM:Problem Investigation`.`Categorization Tier 1` IN ('Change'))\r\n) T0\r\nLEFT OUTER JOIN (\r\n   SELECT DISTINCT\r\n      `PBM:Investigation Associations`.`Request ID02` AS C2,\r\n      `CHG:CHANGEINTERFACE`.`Infrastructure Change ID` AS C3,\r\n      `CHG:CHANGEINTERFACE`.`Change Timing` AS C4\r\n   FROM `AR System Schema`.`PBM:Investigation Associations`\r\n   LEFT OUTER JOIN `AR System Schema`.`CHG:ChangeInterface` AS `CHG:CHANGEINTERFACE`\r\n   ON (`PBM:Investigation Associations`.`Request ID01` = `CHG:CHANGEINTERFACE`.`Infrastructure Change ID`)\r\n   WHERE (`PBM:Investigation Associations`.`Request ID01` LIKE 'CRQ%')\r\n) T1\r\nON T0.C1 = T1.C2) AS `Problemchange`\r\n   ON (`PBM:Problem Investigation`.`Problem Investigation ID` = `Problemchange`.`problemid`)\r\n\r\nWHERE (`PBM:Problem Investigation`.`Problem Investigation ID` IS NOT NULL)\r\n  AND \r\n  (`PBM:Problem Investigation`.`Investigation Status` IN ('Closed')\r\n    AND `PBM:Problem Investigation`.`Categorization Tier 1` IN ('Change')\r\n    AND `PBM:Problem Investigation`.`Investigation Driver` IN ('High Impact Incident')\r\n    AND `PBM:Problem Investigation`.`Closed_Date` \u003e= $__from/1000 and `PBM:Problem Investigation`.`Closed_Date` \u003c= $__to/1000\r\n    AND `Problemchange`.`changeid` IS NULL\r\n   )\r\n) T0\r\nLEFT OUTER JOIN (\r\n   SELECT DISTINCT\r\n      `PBM:Problem Investigation`.`Problem Investigation ID` AS C27\r\n   FROM `AR System Schema`.`PBM:Problem Investigation`\r\n   WHERE (\r\n      `PBM:Problem Investigation`.`Problem Investigation ID` IS NOT NULL\r\n   )\r\n) T1\r\nON T0.C1 = T1.C27"},"sourceType":"remedy"}],"title":"Problem requests from Unplanned Change requests","transforma